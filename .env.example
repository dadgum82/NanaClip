# NanaClip environment variables
# Copy to .env and adjust as needed, or set directly in docker-compose.yml

# ── Target URL ────────────────────────────────────────────────────────────────
HT_URL=https://www.harristeeter.com/savings/cl/coupons/

# ── Coupon clip button selector ───────────────────────────────────────────────
# Kroger/HT's design system uses data-testid="CouponCard-clip-button".
# If the selector stops matching after a site update, override here —
# no Docker rebuild required.
CLIP_SELECTOR=button[data-testid="CouponCard-clip-button"]:not([disabled])

# ── Scroll behavior ───────────────────────────────────────────────────────────
# Maximum number of scroll iterations before giving up on loading more coupons.
# 60 iterations safely covers 300+ coupons at ~1200ms per scroll.
MAX_SCROLL_ITERATIONS=60

# ── Human-like pacing (milliseconds) ─────────────────────────────────────────
# Random delay range between individual coupon clips.
# Akamai's behavioral window is ~60 seconds; staying above 250ms keeps
# the average clip rate well within human range.
JITTER_MIN=250
JITTER_MAX=600

# ── Development / testing helpers ─────────────────────────────────────────────
# Set to "true" to scroll and discover coupons without actually clicking.
# Useful for verifying selectors after a Harris Teeter DOM update.
DRY_RUN=false

# Limit the number of coupons clipped in one run.
# Leave blank (or unset) for unlimited.  Set to "1" for a smoke test.
MAX_CLIPS=

# ── Auth / paths (Docker defaults are usually fine) ───────────────────────────
# Directory where auth.json is read from inside the container.
# Matches the /config volume mount in docker-compose.yml.
CONFIG_DIR=/config
